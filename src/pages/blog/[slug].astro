---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} | IZITech`} description={post.data.description}>
  <Header />
  <main class="mx-auto min-h-[70vh] max-w-3xl px-5 py-14">
    <a class="text-sm font-bold text-brand hover:text-brand-dark" href="/blog">Voltar ao blog</a>
    <p class="mt-8 text-sm font-bold text-slate-500">{post.data.pubDate.toLocaleDateString('pt-PT')} · {post.data.author}</p>
    <h1 class="mt-3 text-4xl font-black leading-tight text-ink md:text-5xl">{post.data.title}</h1>
    <p class="mt-5 text-lg leading-8 text-slate-600">{post.data.description}</p>
    <article class="content mt-10">
      <Content />
    </article>
  </main>
  <Footer />
</BaseLayout>
