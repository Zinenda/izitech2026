---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const posts = (await getCollection("blog")).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Blog IZITech" description="Conteúdos da IZITech sobre consultoria informática, transformação digital, infraestrutura, cloud, suporte técnico e produtividade empresarial.">
  <section class="section-pad pt-40">
    <div class="container-premium">
      <div class="max-w-3xl">
        <h1 class="text-balance text-5xl font-black leading-tight sm:text-7xl" data-i18n="blog.title">Insights IZITech</h1>
        <p class="mt-6 text-xl leading-9 text-muted" data-i18n="blog.copy">Conteúdos sobre consultoria informática, transformação digital, infraestrutura, cloud, suporte técnico e produtividade empresarial.</p>
      </div>
      {posts.length === 0 ? (
        <p class="mt-12 text-muted" data-i18n="empty.blog">Novos artigos serão publicados em breve.</p>
      ) : (
        <div class="mt-12 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
          {posts.map((post) => (
            <article class="premium-card p-6">
              <p class="text-xs font-black uppercase text-izired">{post.data.category}</p>
              <h2 class="mt-5 text-2xl font-black" data-pt={post.data.title} data-en={post.data.titleEn}>{post.data.title}</h2>
              <p class="mt-4 leading-7 text-muted" data-pt={post.data.description} data-en={post.data.descriptionEn}>{post.data.description}</p>
              <a class="mt-6 inline-flex text-sm font-black text-white hover:text-izired" href={`/blog/${post.id.replace(/\.md$/, "")}`} data-i18n="blog.read">Ler artigo</a>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
