---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
---

<BaseLayout title="Blog | IZITech" description="Artigos publicados pelo CMS.">
  <Header />
  <main class="mx-auto min-h-[70vh] max-w-6xl px-5 py-14">
    <h1 class="text-4xl font-black text-ink md:text-5xl">Blog</h1>
    <div class="mt-8 grid gap-5">
      {posts.map((post) => (
        <article class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
          <p class="text-sm font-bold text-brand">{post.data.pubDate.toLocaleDateString('pt-PT')}</p>
          <h2 class="mt-3 text-2xl font-black text-ink">
            <a href={`/blog/${post.id}`}>{post.data.title}</a>
          </h2>
          <p class="mt-3 max-w-3xl leading-7 text-slate-600">{post.data.description}</p>
        </article>
      ))}
    </div>
  </main>
  <Footer />
</BaseLayout>
