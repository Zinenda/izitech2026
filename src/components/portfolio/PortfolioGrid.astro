---
const projects = [
  ["IT Consulting & Digital Transformation", "Consultoria e Transformação Digital", "Consultoria", "Diagnóstico tecnológico, planeamento estratégico de TI e optimização de infraestruturas para empresas e instituições.", "Technology diagnosis, IT strategic planning, and infrastructure optimization for companies and institutions.", "TI"],
  ["Corporate Web Platforms", "Plataformas Web Corporativas", "Web", "Websites institucionais, portais, lojas online, landing pages e sistemas web com SEO e manutenção contínua.", "Institutional websites, portals, online stores, landing pages, and web systems with SEO and ongoing maintenance.", "Digital"],
  ["Cloud, Hosting & Corporate Email", "Cloud, Hospedagem e Email Corporativo", "Cloud", "Hospedagem web, email empresarial, domínios, DNS, VPS, backup em nuvem e migração de emails através da IZIHost.", "Web hosting, business email, domains, DNS, VPS, cloud backup, and email migration through IZIHost.", "IZIHost"],
  ["Technical Support & Infrastructure", "Suporte Técnico e Infraestrutura", "Suporte", "Redes, servidores, equipamentos informáticos, manutenção preventiva, recuperação de dados e contratos de suporte.", "Networks, servers, IT equipment, preventive maintenance, data recovery, and support contracts.", "Operação"]
];

const filters = [
  ["All", "Todos", "All"],
  ["Consultoria", "Consultoria", "Consulting"],
  ["Web", "Web", "Web"],
  ["Cloud", "Cloud", "Cloud"],
  ["Suporte", "Suporte", "Support"]
];
---

<section id="portfolio" class="section-pad">
  <div class="container-premium">
    <div class="reveal flex flex-col justify-between gap-6 md:flex-row md:items-end">
      <div class="max-w-3xl">
        <h2 class="text-balance text-4xl font-black leading-tight sm:text-5xl" data-i18n="portfolio.title">Soluções preparadas para a operação real</h2>
        <p class="mt-5 text-lg text-muted" data-i18n="portfolio.copy">Actuamos em consultoria, web, cloud, redes, sistemas, licenciamento, suporte técnico, design e automação.</p>
      </div>
      <div class="flex gap-2" aria-label="Portfolio filters">
        {filters.map(([filter, labelPt, labelEn]) => (
          <button class="portfolio-filter rounded-full border border-line px-4 py-2 text-sm font-black text-muted transition hover:text-white" type="button" data-filter={filter} data-pt={labelPt} data-en={labelEn}>{labelPt}</button>
        ))}
      </div>
    </div>
    <div class="portfolio-grid mt-12 grid gap-5 md:grid-cols-2">
      {projects.map(([titleEn, titlePt, category, summaryPt, summaryEn, year]) => (
        <article class="portfolio-card reveal premium-card group cursor-pointer overflow-hidden" data-category={category} data-title-pt={titlePt} data-title-en={titleEn} data-summary-pt={summaryPt} data-summary-en={summaryEn}>
          <div class="aspect-[16/9] bg-[radial-gradient(circle_at_30%_20%,rgba(204,0,0,.45),transparent_28%),linear-gradient(135deg,#191919,#050505)] p-5">
            <div class="h-full rounded-[18px] border border-white/10 bg-black/30 p-5 transition duration-300 group-hover:scale-[1.015]">
              <div class="flex justify-between text-xs font-black uppercase text-muted">
                <span>{category}</span>
                <span>{year}</span>
              </div>
              <div class="mt-16 h-3 w-28 rounded-full bg-izired"></div>
              <div class="mt-4 h-4 w-3/4 rounded-full bg-white/25"></div>
              <div class="mt-3 h-4 w-1/2 rounded-full bg-white/10"></div>
            </div>
          </div>
          <div class="p-6">
            <h3 class="text-2xl font-black" data-pt={titlePt} data-en={titleEn}>{titlePt}</h3>
            <p class="mt-3 leading-7 text-muted" data-pt={summaryPt} data-en={summaryEn}>{summaryPt}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
  <dialog class="portfolio-modal w-[min(720px,calc(100%-32px))] rounded-[28px] border border-line bg-card p-0 text-white backdrop:bg-black/70">
    <div class="p-6 sm:p-8">
      <button class="modal-close float-right grid h-10 w-10 place-items-center rounded-full border border-line text-xl" type="button" aria-label="Close preview">×</button>
      <p class="text-sm font-black uppercase text-izired">IZITech Portfolio</p>
      <h3 class="modal-title mt-5 text-3xl font-black"></h3>
      <p class="modal-summary mt-4 leading-8 text-muted"></p>
    </div>
  </dialog>
</section>
