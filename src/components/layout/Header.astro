---
const navItems = [
  ["nav.home", "/"],
  ["nav.about", "/#about"],
  ["nav.services", "/#services"],
  ["nav.clients", "/#clients"],
  ["nav.portfolio", "/#portfolio"],
  ["nav.blog", "/blog"],
  ["nav.faq", "/#faq"],
  ["nav.contact", "/#contact"]
];

const currentPath = Astro.url.pathname;
const normalizePath = (path: string) => path.replace(/\/$/, "") || "/";
const isActive = (href: string) => {
  if (href.includes("#")) return false;
  return normalizePath(currentPath) === normalizePath(href);
};
---

<header class="fixed inset-x-0 top-0 z-50 px-3 pt-3 sm:px-4 sm:pt-4">
  <nav class="glass mx-auto flex h-[68px] max-w-[1180px] items-center justify-between rounded-full px-3 shadow-[0_22px_80px_rgba(0,0,0,.36)] ring-1 ring-white/[.05] sm:px-4" aria-label="Primary navigation">
    <a href="/" class="group flex min-w-0 items-center gap-3 rounded-full py-1.5 pr-2 transition hover:bg-white/[.04] sm:pr-4" aria-label="IZITech home">
      <span class="grid h-11 w-11 shrink-0 place-items-center rounded-full bg-izired shadow-[0_12px_28px_rgba(204,0,0,.35)] ring-1 ring-white/15">
        <img class="h-7 w-7" src="/logoIZI-inverse.svg" alt="" width="28" height="28" loading="eager" />
      </span>
      <span class="hidden leading-none sm:block">
        <span class="block text-sm font-black uppercase text-white">IZITech</span>
        <span class="mt-1 block text-[10px] font-bold uppercase text-muted">Technologies & Services</span>
      </span>
    </a>

    <div class="hidden items-center gap-1 rounded-full border border-white/[.06] bg-white/[.025] p-1 lg:flex">
      {navItems.map(([key, href]) => (
        <a
          class:list={[
            "rounded-full px-3.5 py-2 text-sm font-bold transition",
            isActive(href) ? "bg-white text-ink shadow-sm" : "text-muted hover:bg-white/[.07] hover:text-white"
          ]}
          href={href}
          data-i18n={key}
          aria-current={isActive(href) ? "page" : undefined}
        >
          {key}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-2">
      <div class="language-switcher flex rounded-full border border-white/[.08] bg-white/[.04] p-1" aria-label="Language switcher">
        <button class="lang-btn rounded-full px-3 py-1.5 text-xs font-black text-muted transition" type="button" data-lang="pt" aria-pressed="true">PT</button>
        <button class="lang-btn rounded-full px-3 py-1.5 text-xs font-black text-muted transition" type="button" data-lang="en" aria-pressed="false">EN</button>
      </div>
      <a
        href="/contact"
        class="hidden min-h-10 items-center justify-center rounded-full border border-[rgba(255,80,80,.46)] bg-[linear-gradient(135deg,#f03,#cc0000_55%,#8f0000)] px-4 py-2 text-xs font-black text-white shadow-[0_12px_28px_rgba(204,0,0,.28)] transition hover:-translate-y-0.5 sm:inline-flex"
        data-i18n="cta.primary"
      >
        Iniciar projecto
      </a>
      <button class="mobile-toggle grid h-10 w-10 place-items-center rounded-full border border-white/[.08] bg-white/[.04] text-white transition hover:bg-white/[.08] lg:hidden" type="button" aria-expanded="false" aria-controls="mobile-menu" aria-label="Open menu">
        <span class="h-0.5 w-5 rounded bg-current shadow-[0_6px_0_currentColor,0_-6px_0_currentColor]"></span>
      </button>
    </div>
  </nav>
  <div id="mobile-menu" class="glass mx-auto mt-3 hidden max-w-[1180px] rounded-3xl p-3 shadow-[0_22px_80px_rgba(0,0,0,.36)] lg:hidden">
    {navItems.map(([key, href]) => (
      <a
        class:list={[
          "block rounded-2xl px-4 py-3 text-sm font-bold transition",
          isActive(href) ? "bg-white text-ink" : "text-muted hover:bg-white/5 hover:text-white"
        ]}
        href={href}
        data-i18n={key}
        aria-current={isActive(href) ? "page" : undefined}
      >
        {key}
      </a>
    ))}
  </div>
</header>
