<section class="relative flex min-h-screen items-center overflow-hidden pt-28">
  <div class="absolute inset-0 -z-10 bg-[linear-gradient(135deg,rgba(204,0,0,.16),transparent_32%),linear-gradient(180deg,#050505_0%,#0b0505_100%)]"></div>
  <div class="container-premium pb-10">
    <div class="grid items-center gap-8 rounded-[2rem] border border-white/[.08] bg-white/[.035] p-5 shadow-[0_30px_100px_rgba(0,0,0,.42)] backdrop-blur-xl sm:gap-10 sm:p-8 lg:grid-cols-[.95fr_1.05fr] lg:p-12">
      <div>
        <h1 class="hero-line max-w-3xl text-balance text-[clamp(2.5rem,6.8vw,5.9rem)] font-black leading-[.92] tracking-[0]" data-i18n="hero.title">
        Soluções tecnológicas para empresas em Moçambique
        </h1>
        <p class="hero-line mt-7 max-w-2xl text-lg leading-8 text-mist sm:text-xl" data-i18n="hero.copy">
          A IZITech fornece consultoria informática, suporte técnico, desenvolvimento web, cloud, email corporativo, design gráfico, sistemas empresariais e automação para organizações que querem modernizar processos com segurança e eficiência.
        </p>
        <div class="hero-line mt-9 flex flex-col gap-3 sm:flex-row">
          <a class="btn btn-primary" href="/contact" data-i18n="cta.primary">Iniciar projecto</a>
          <a class="btn btn-secondary" href="/services" data-i18n="cta.secondary">Ver serviços</a>
        </div>

        <div class="hero-line mt-12 hidden max-w-xl grid-cols-3 divide-x divide-white/10 border-y border-white/10 py-5 sm:grid">
          <div>
            <div class="text-2xl font-black text-white">9+</div>
            <div class="mt-1 text-[11px] font-bold uppercase text-muted" data-pt="Anos de experiência" data-en="Years of experience">Anos de experiência</div>
          </div>
          <div class="px-4">
            <div class="text-2xl font-black text-white">250+</div>
            <div class="mt-1 text-[11px] font-bold uppercase text-muted" data-pt="Projectos executados" data-en="Executed projects">Projectos executados</div>
          </div>
          <div class="px-4">
            <div class="text-2xl font-black text-white">9</div>
            <div class="mt-1 text-[11px] font-bold uppercase text-muted" data-pt="Áreas" data-en="Areas">Áreas</div>
          </div>
        </div>
      </div>

      <div class="hero-line relative min-h-[390px] sm:min-h-[560px]">
        <div class="absolute right-0 top-0 h-24 w-24 rounded-full border border-izired/30"></div>
        <div class="absolute left-8 top-16 hidden h-5 w-5 rotate-45 border border-white/25 sm:block"></div>
        <div class="absolute bottom-10 right-16 hidden h-4 w-4 rounded-full bg-izired shadow-[0_0_28px_rgba(204,0,0,.75)] sm:block"></div>

        <figure class="absolute left-0 top-6 w-[48%] overflow-hidden rounded-[2rem] border border-white/10 bg-card shadow-[0_24px_70px_rgba(0,0,0,.42)]">
          <img class="aspect-[.86/1] h-full w-full object-cover" src="/images/hero/student-designer.jpg" alt="Jovem estudante africana negra a trabalhar em design digital com tablet e caderno" width="1200" height="1200" loading="eager" />
        </figure>

        <figure class="absolute right-0 top-20 w-[43%] overflow-hidden rounded-[2rem] border border-white/10 bg-card shadow-[0_24px_70px_rgba(0,0,0,.42)]">
          <img class="aspect-[.82/1] h-full w-full object-cover" src="/images/hero/it-student.jpg" alt="Jovem estudante africano negro de IT com laptop em ambiente de programação" width="1200" height="1200" loading="eager" />
        </figure>

        <figure class="absolute bottom-14 left-[12%] w-[70%] overflow-hidden rounded-[2rem] border border-white/10 bg-card shadow-[0_24px_70px_rgba(0,0,0,.46)] sm:bottom-10 lg:bottom-8">
          <img class="aspect-[1.72/1] h-full w-full object-cover" src="/images/hero/design-it-collab.jpg" alt="Jovens africanos negros estudantes de design e IT a colaborar num projecto digital" width="1400" height="933" loading="eager" />
        </figure>

        <div class="absolute left-[44%] top-[45%] rounded-full border border-white/10 bg-white px-5 py-3 text-xs font-black uppercase text-ink shadow-[0_22px_60px_rgba(0,0,0,.32)]">
          TI + Digital
        </div>

        <div class="absolute bottom-2 right-4 rounded-2xl border border-izired/25 bg-black/70 px-4 py-3 shadow-[0_18px_50px_rgba(0,0,0,.35)] backdrop-blur sm:bottom-4">
          <div class="text-sm font-black text-white" data-pt="Soluções integradas" data-en="Integrated solutions">Soluções integradas</div>
          <div class="mt-1 text-xs text-muted">Consultoria • Web • Cloud • Suporte</div>
        </div>
      </div>
    </div>

    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      {["hero.metric1", "hero.metric2", "hero.metric3"].map((key) => (
        <div class="reveal rounded-2xl border border-line bg-white/[.035] p-4 text-sm font-bold text-mist" data-i18n={key}>{key}</div>
      ))}
    </div>
  </div>
</section>
