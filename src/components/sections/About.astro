<section id="about" class="section-pad">
  <div class="container-premium grid gap-10 lg:grid-cols-[.9fr_1.1fr]">
    <div class="reveal">
      <h2 class="max-w-xl text-balance text-4xl font-black leading-tight sm:text-5xl" data-i18n="about.title">Empresa moçambicana de tecnologia e serviços digitais</h2>
      <p class="mt-6 text-lg leading-8 text-muted" data-i18n="about.copy">
        Fundada na Cidade de Tete, a IZITech surgiu para apoiar pequenas, médias e grandes organizações na modernização dos seus processos tecnológicos, com soluções profissionais, inovadoras, acessíveis e adaptadas à realidade empresarial moçambicana.
      </p>
    </div>
    <div class="grid gap-4">
      {[
        ["about.mission", "about.missionText"],
        ["about.vision", "about.visionText"],
        ["about.values", "about.valuesText"]
      ].map(([title, text]) => (
        <article class="reveal premium-card magic-card p-6">
          <h3 class="text-xl font-black" data-i18n={title}>{title}</h3>
          <p class="mt-3 leading-7 text-muted" data-i18n={text}>{text}</p>
        </article>
      ))}
    </div>
  </div>
</section>
